# NextAuth (v5): genera AUTH_SECRET con `openssl rand -base64 32`
AUTH_SECRET=

# Usuario demo (único permitido en modo credenciales de este boilerplate)
AUTH_DEMO_EMAIL=admin@ejemplo.com
# Contraseña demo (use OAuth o proveedor gestionado en producción)
AUTH_DEMO_PASSWORD=cambiar-en-produccion

AUTH_DEMO_NAME=Administrador

# Supabase (Auth / datos): proyecto en https://supabase.com/dashboard — no subas claves reales al repo
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Marca multi-tenant (público, seguro en el cliente)
NEXT_PUBLIC_APP_NAME=U-Pass Parking
NEXT_PUBLIC_TENANT_SHORT_NAME=U-Pass
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@tu-empresa.com
NEXT_PUBLIC_LOGO_PATH=/tenant/logo.svg
# NEXT_PUBLIC_LOGO_URL=https://cdn.tu-empresa.com/logo.svg
NEXT_PUBLIC_PRIMARY_HUE=217
