# NextAuth (v5): genera AUTH_SECRET con `openssl rand -base64 32`
AUTH_SECRET=

# --- Microsoft Entra ID (opcional; si está completo, aparece "Continuar con Microsoft" en /login)
# Registrar app en Azure y usar la URL de callback: https://<host>/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Recomendado: GUID del directorio (tenant) para solo cuentas de tu organización
# AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=

# --- Credenciales demo (opcional; desactívalas en producción dejando vacío AUTH_DEMO_PASSWORD)
AUTH_DEMO_EMAIL=admin@ejemplo.com
AUTH_DEMO_PASSWORD=cambiar-en-produccion
AUTH_DEMO_NAME=Administrador

# --- Notificaciones por correo (Resend: https://resend.com )
# RESEND_API_KEY=
# Remitente verificado en Resend (ej. onboarding@resend.dev en pruebas)
NOTIFICATIONS_FROM_EMAIL=onboarding@resend.dev
# Bienvenida tras login: off | new_user_only | each_signin
NOTIFICATIONS_WELCOME=off

# Marca multi-tenant (público, seguro en el cliente)
NEXT_PUBLIC_APP_NAME=U-Pass Parking
NEXT_PUBLIC_TENANT_SHORT_NAME=U-Pass
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@tu-empresa.com
NEXT_PUBLIC_LOGO_PATH=/tenant/logo.svg
# NEXT_PUBLIC_LOGO_URL=https://cdn.tu-empresa.com/logo.svg
NEXT_PUBLIC_PRIMARY_HUE=217
