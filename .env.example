# Copia a `.env.local` y completa los valores.

# --- Supabase (requerido para login/registro con correo)
# Proyecto: https://supabase.com/dashboard → Settings → API
# Auth usa las tablas internas `auth.users` de Supabase (no las modifiques a mano).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# En Supabase: Authentication → URL configuration → Redirect URLs debe incluir:
# https://<tu-dominio>/auth/callback  y http://localhost:3000/auth/callback

# --- Notificaciones por correo (Resend: https://resend.com )
# RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL=onboarding@resend.dev
# Bienvenida: off | new_user_only | each_signin
NOTIFICATIONS_WELCOME=off

# Marca multi-tenant (público)
NEXT_PUBLIC_APP_NAME=U-Pass Parking
NEXT_PUBLIC_TENANT_SHORT_NAME=U-Pass
NEXT_PUBLIC_SUPPORT_EMAIL=soporte@tu-empresa.com
NEXT_PUBLIC_LOGO_PATH=/tenant/logo.svg
# NEXT_PUBLIC_LOGO_URL=https://cdn.tu-empresa.com/logo.svg
